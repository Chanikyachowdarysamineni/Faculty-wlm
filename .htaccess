# .htaccess for Apache (Alternative to apache.conf)
# Place this in /var/www/html/csefaculty/.htaccess

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /csefaculty/
    
    # Remove index.html from URL
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.html [L]
    
    # If not a real file or directory, route to index.html
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
</IfModule>

<IfModule mod_headers.c>
    # Cache control
    <FilesMatch "index\.html$">
        Header set Cache-Control "public, max-age=0, must-revalidate"
    </FilesMatch>
    
    <FilesMatch "static/.*\.js$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "static/.*\.css$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "\.(png|jpg|jpeg|gif|svg|webp)$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>
    
    # Security headers
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>
